# LoomQuery Environment Variables

# ChromaDB
CHROMA_URL=http://localhost:8000

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Embedding Provider
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# OpenAI (optional, alternative to Ollama)
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# LLM Provider
LLM_PROVIDER=ollama
OLLAMA_LLM_MODEL=llama3.2

# BullMQ Worker (Admin/Testing)
# Required in production for /api/queue/start endpoint authentication
# In development (NODE_ENV !== production), all requests are allowed
# In production, requests must include: Authorization: Bearer <QUEUE_ADMIN_SECRET>
# QUEUE_ADMIN_SECRET=your-secret-token-here

# Application
NODE_ENV=development
PORT=3000
DATA_DIR=./data
